# ══════════════════════════════════════════════════════════════════════════════
# FRAUD DETECTION MLOPS - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git (secrets!)

# ── Database Configuration ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/fraud_detection
DATABASE_ECHO=False

# ── API Configuration ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY_HEADER=X-API-Key

# ── MLflow Configuration ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud_detection
MLFLOW_BACKEND_STORE_URI=file:///mlruns

# ── Logging Configuration ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/fraud_detection.log
LOG_FORMAT=json

# ── Model Configuration ────────────────────────────────────────────────────
MODEL_VERSION=1
MODEL_PATH=models/
SCALER_PATH=models/scaler.pkl
FEATURE_COLUMNS_PATH=models/feature_columns.pkl

# ── Data Configuration ────────────────────────────────────────────────────
RAW_DATA_DIR=data/raw/ieee-fraud-detection/
PROCESSED_DATA_DIR=data/processed/
TEST_SIZE=0.2
RANDOM_STATE=42

# ── AWS Configuration (for deployment) ──────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=fraud-detection-models

# ── Monitoring ────────────────────────────────────────────────────────────
MONITORING_ENABLED=True
DRIFT_THRESHOLD=0.05
RETRAINING_FREQUENCY_DAYS=7

# ── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development
# development, staging, production